{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "America/Chicago",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 20,
  "rangeStrategy": "bump",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["Rubio-Enterprises/standards"],
      "groupName": "rubio-standards-template",
      "labels": ["dependencies", "standards-template-drift"],
      "commitMessageTopic": "rubio-standards template",
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)\\.copier-answers\\.yml$"],
      "matchStrings": [
        "_commit:\\s*template/(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "Rubio-Enterprises/standards",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^template/(?<version>v\\d+\\.\\d+\\.\\d+)$"
    }
  ]
}
